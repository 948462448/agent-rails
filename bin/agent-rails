#!/usr/bin/env bash
set -euo pipefail
source_path="${BASH_SOURCE[0]}"
while [[ -L "$source_path" ]]; do
  source_dir="$(cd -P "$(dirname "$source_path")" && pwd)"
  source_target="$(readlink "$source_path")"
  [[ "$source_target" == /* ]] && source_path="$source_target" || source_path="$source_dir/$source_target"
done
script_dir="$(cd -P "$(dirname "$source_path")" && pwd)"
export AGENT_RAILS_HOME="$(cd -P "$script_dir/.." && pwd)"
exec python3 -E "$AGENT_RAILS_HOME/scripts/agent-python-cli.py" public "$@"
