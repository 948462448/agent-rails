#!/usr/bin/env bash
# Personal Agent Rails CLI. Keeps the kit separate from target repositories.

set -euo pipefail

source_path="${BASH_SOURCE[0]}"
while [[ -L "$source_path" ]]; do
  source_dir="$(cd "$(dirname "$source_path")" && pwd)"
  source_target="$(readlink "$source_path")"
  if [[ "$source_target" == /* ]]; then
    source_path="$source_target"
  else
    source_path="$source_dir/$source_target"
  fi
done
script_dir="$(cd "$(dirname "$source_path")" && pwd)"
AGENT_RAILS_HOME="$(cd "$script_dir/.." && pwd)"
export AGENT_RAILS_HOME
# shellcheck source=scripts/agent-paths.sh
source "$AGENT_RAILS_HOME/scripts/agent-paths.sh"
agent_rails_init_paths
AGENT_RAILS_VERSION="$(agent_rails_version)"
export AGENT_RAILS_VERSION

usage() {
  cat <<'USAGE'
Usage:
  agent-rails setup [--project PATH] [--profile PATH] [--tool auto|claude|codex|opencode|all] [--no-session-hook] [--dry-run]
  agent-rails run [--project PATH] [--profile PATH] [--model NAME] [--pack-mode lite|normal|deep|audit] [goal text...]
  agent-rails verify [--project PATH] [--profile PATH] [--print-only] [--publish] [--base REF] [--target-ref REF] [--no-secret-scan]

Advanced:
  agent-rails --version
  agent-rails version
  agent-rails update --tool claude|codex|opencode [--project PATH] [--profile PATH] [--mode local|project] [--session-hook] [--global-reminder] [--skip-pull] [--skip-tests] [--skip-doctor] [--skip-adapter] [--dry-run]
  agent-rails upgrade self [--version VERSION] [--repository OWNER/REPO] [--install-root PATH] [--bin-dir PATH] [--skip-tests] [--dry-run]
  agent-rails init [--shell zsh|bash|fish] [--project PATH] [--profile PATH]
  agent-rails pack [--project PATH] [agent-context-pack args...]
  agent-rails check [--project PATH] [agent-check args...]
  agent-rails publish check [--project PATH] [--profile PATH] [--base REF] [--target-ref REF] [--no-secret-scan]
  agent-rails estimate [--profile PATH] [--model NAME] [--tokenizer auto|char|tiktoken|command|huggingface] [--tokenizer-command CMD] [--tokenizer-path PATH] [--file PATH] [text...]
  agent-rails doctor [--project PATH] [--profile PATH] [--openmemory-smoke]
  agent-rails profile init [--project PATH] [--name NAME] [--scope user|project] [--print-only]
  agent-rails claude install [--project PATH] [--profile PATH] [--mode local|project] [--global-reminder] [--session-hook]
  agent-rails claude uninstall [--project PATH] [--global-reminder] [--session-hook] [--dry-run]
  agent-rails codex install [--project PATH] [--profile PATH] [--fix-project] [--dry-run]
  agent-rails codex doctor [--project PATH]
  agent-rails codex uninstall [--dry-run]
  agent-rails opencode install [--project PATH] [--profile PATH] [--dry-run] [--force]
  agent-rails opencode doctor [--project PATH]
  agent-rails opencode uninstall [--project PATH] [--dry-run] [--force]
  agent-rails memory suggest [--project PATH] [--profile PATH] [--decision keep|skip|update|merge] [--write-local] [notes...]
  agent-rails skills install --dest PATH [--dry-run] [skill-name...]
  agent-rails home

Examples:
  agent-rails setup --tool claude
  agent-rails run "review current changes"
  agent-rails verify
  agent-rails verify --publish --base <deployed-revision>

Run `agent-rails <command> --help` for advanced command details.
USAGE
}

command="${1:-}"
if [[ "$command" == "--version" || "$command" == "version" ]]; then
  printf 'agent-rails %s\n' "$AGENT_RAILS_VERSION"
  exit 0
fi

if [[ -z "$command" || "$command" == "--help" || "$command" == "-h" ]]; then
  usage
  exit 0
fi
shift || true

run_in_project() {
  local script="$1"
  shift
  local project="$PWD"
  local args=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --project)
        [[ $# -ge 2 ]] || { usage >&2; exit 2; }
        project="$2"
        shift 2
        ;;
      *)
        args+=("$1")
        shift
        ;;
    esac
  done

  cd "$project"
  if [[ "${#args[@]}" -gt 0 ]]; then
    "$AGENT_RAILS_HOME/scripts/$script" "${args[@]}"
  else
    "$AGENT_RAILS_HOME/scripts/$script"
  fi
}

case "$command" in
  setup)
    "$AGENT_RAILS_HOME/scripts/agent-setup.sh" "$@"
    ;;
  update)
    "$AGENT_RAILS_HOME/scripts/agent-update.sh" "$@"
    ;;
  upgrade)
    subcommand="${1:-}"
    case "$subcommand" in
      self)
        shift
        "$AGENT_RAILS_HOME/scripts/agent-update.sh" --self-only "$@"
        ;;
      ""|--help|-h)
        "$AGENT_RAILS_HOME/scripts/agent-update.sh" --help
        ;;
      *)
        usage >&2
        exit 2
        ;;
    esac
    ;;
  init)
    "$AGENT_RAILS_HOME/scripts/agent-init-shell.sh" "$@"
    ;;
  pack)
    run_in_project agent-context-pack.sh "$@"
    ;;
  run)
    "$AGENT_RAILS_HOME/scripts/agent-run.sh" "$@"
    ;;
  verify)
    "$AGENT_RAILS_HOME/scripts/agent-verify.sh" "$@"
    ;;
  check)
    run_in_project agent-check.sh "$@"
    ;;
  publish)
    subcommand="${1:-}"
    case "$subcommand" in
      check)
        shift
        run_in_project agent-publish-check.sh "$@"
        ;;
      ""|--help|-h)
        "$AGENT_RAILS_HOME/scripts/agent-publish-check.sh" --help
        ;;
      *)
        usage >&2
        exit 2
        ;;
    esac
    ;;
  estimate)
    "$AGENT_RAILS_HOME/scripts/agent-estimate.sh" "$@"
    ;;
  doctor)
    "$AGENT_RAILS_HOME/scripts/agent-doctor.sh" "$@"
    ;;
  profile)
    subcommand="${1:-}"
    if [[ "$subcommand" != "init" ]]; then
      usage >&2
      exit 2
    fi
    shift
    "$AGENT_RAILS_HOME/scripts/agent-init-profile.sh" "$@"
    ;;
  claude)
    subcommand="${1:-}"
    case "$subcommand" in
      install)
        shift
        "$AGENT_RAILS_HOME/scripts/agent-install-claude.sh" "$@"
        ;;
      upgrade)
        shift
        printf 'Deprecated: use `agent-rails doctor --fix` for repair, `agent-rails update --tool claude` for project maintenance, or `agent-rails upgrade self` for kit-only updates.\n' >&2
        "$AGENT_RAILS_HOME/scripts/agent-install-claude.sh" --force "$@"
        ;;
      uninstall)
        shift
        "$AGENT_RAILS_HOME/scripts/agent-uninstall-claude.sh" "$@"
        ;;
      *)
        usage >&2
        exit 2
        ;;
    esac
    ;;
  codex)
    "$AGENT_RAILS_HOME/scripts/agent-codex.sh" "$@"
    ;;
  opencode)
    "$AGENT_RAILS_HOME/scripts/agent-opencode.sh" "$@"
    ;;
  memory)
    subcommand="${1:-}"
    if [[ "$subcommand" != "suggest" ]]; then
      usage >&2
      exit 2
    fi
    shift
    "$AGENT_RAILS_HOME/scripts/agent-memory-suggest.sh" "$@"
    ;;
  skills)
    subcommand="${1:-}"
    if [[ "$subcommand" != "install" ]]; then
      usage >&2
      exit 2
    fi
    shift
    "$AGENT_RAILS_HOME/scripts/agent-install-skills.sh" "$@"
    ;;
  home)
    printf '%s\n' "$AGENT_RAILS_HOME"
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac
