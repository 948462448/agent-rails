#!/usr/bin/env bash
# Personal Agent Rails CLI. Keeps the kit separate from target repositories.

set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
AGENT_RAILS_HOME="${AGENT_RAILS_HOME:-$(cd "$script_dir/.." && pwd)}"
export AGENT_RAILS_HOME

usage() {
  cat <<'USAGE'
Usage:
  agent-rails pack [--project PATH] [agent-context-pack args...]
  agent-rails check [--project PATH] [agent-check args...]
  agent-rails skills install --dest PATH [--dry-run] [skill-name...]
  agent-rails home

Examples:
  agent-rails pack --project /path/to/open-eval --target-ref my-branch "review trajectory eval"
  agent-rails check --project /path/to/open-eval --print-only
  agent-rails skills install --dest /path/to/open-eval/.claude/skills agent-context-pack agent-check
USAGE
}

command="${1:-}"
if [[ -z "$command" || "$command" == "--help" || "$command" == "-h" ]]; then
  usage
  exit 0
fi
shift || true

run_in_project() {
  local script="$1"
  shift
  local project="$PWD"
  local args=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --project)
        [[ $# -ge 2 ]] || { usage >&2; exit 2; }
        project="$2"
        shift 2
        ;;
      *)
        args+=("$1")
        shift
        ;;
    esac
  done

  cd "$project"
  "$AGENT_RAILS_HOME/scripts/$script" "${args[@]}"
}

case "$command" in
  pack)
    run_in_project agent-context-pack.sh "$@"
    ;;
  check)
    run_in_project agent-check.sh "$@"
    ;;
  skills)
    subcommand="${1:-}"
    if [[ "$subcommand" != "install" ]]; then
      usage >&2
      exit 2
    fi
    shift
    "$AGENT_RAILS_HOME/scripts/agent-install-skills.sh" "$@"
    ;;
  home)
    printf '%s\n' "$AGENT_RAILS_HOME"
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac
